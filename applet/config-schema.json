{
  "layout1": {
    "type": "layout",
    "pages": ["page1"],
    "page1": {
      "type": "page",
      "title": "Virtual HDMI",
      "sections": ["section1"]
    },
    "section1": {
      "type": "section",
      "title": "Resolución por defecto",
      "keys": ["width", "height", "refresh"]
    }
  },

  "width": {
    "type": "spinbutton",
    "default": 2360,
    "min": 640,
    "max": 7680,
    "step": 1,
    "units": "px",
    "description": "Ancho",
    "tooltip": "Se exporta como SUNSHINE_APP_WIDTH al ejecutar 'on'."
  },

  "height": {
    "type": "spinbutton",
    "default": 1640,
    "min": 480,
    "max": 4320,
    "step": 1,
    "units": "px",
    "description": "Alto",
    "tooltip": "Se exporta como SUNSHINE_APP_HEIGHT al ejecutar 'on'."
  },

  "refresh": {
    "type": "spinbutton",
    "default": 60,
    "min": 1,
    "max": 240,
    "step": 1,
    "units": "Hz",
    "description": "Refresco",
    "tooltip": "Se exporta como SUNSHINE_APP_FPS al ejecutar 'on'."
  }
}
